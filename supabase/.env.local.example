# Supabase (auto-populated in production)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Microsoft Azure AD Application (client credentials flow)
# Register an app at https://portal.azure.com → Azure Active Directory → App registrations
# Required API Permissions (Application type):
#   - Mail.ReadWrite
#   - Calendars.ReadWrite
MICROSOFT_TENANT_ID=your-azure-tenant-id
MICROSOFT_CLIENT_ID=your-azure-client-id
MICROSOFT_CLIENT_SECRET=your-azure-client-secret
